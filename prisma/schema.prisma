// Quantchill – Prisma schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  name               String?
  isPremium          Boolean                 @default(false)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  moodProfile        MoodProfile?
  sessions           Session[]
  wellbeingSettings  UserWellbeingSettings?
}

model MoodProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentMood   String   @default("Deep Focus")
  moodHistory   String[] @default([])
  updatedAt     DateTime @updatedAt
}

model Session {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood            String
  startedAt       DateTime         @default(now())
  endedAt         DateTime?
  sessionTime     Int              @default(0)  // seconds elapsed
  paywallShown    Boolean          @default(false)
  quantchatSynced Boolean          @default(false)
  generatedTracks GeneratedTrack[]
}

model GeneratedTrack {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  mood        String
  bpm         Int
  key         String
  scale       String
  intensity   Float
  variation   Int      @default(0)
  generatedAt DateTime @default(now())
}

/// Per-user wellbeing controls.
///
/// All fields default to the least-intrusive value. `hideEloRating` defaults
/// to TRUE so that a user's rating is never shown until they explicitly opt
/// in. `breakRemindersEnabled` defaults to FALSE so the app never surfaces
/// usage nudges without consent.
model UserWellbeingSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hideEloRating         Boolean  @default(true)
  dailyTimeLimitMinutes Int?
  breakRemindersEnabled Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}
